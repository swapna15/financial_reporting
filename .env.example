# Claude API
ANTHROPIC_API_KEY=your_api_key_here

# AWS / S3 — required for cloud deployments; leave blank to use local file
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_DATA_KEY=SAP_GL_Account_Data.xlsx

# Local/Docker Ollama model (optional; ignored when DISABLE_OLLAMA=true)
OLLAMA_MODEL=llama3.2

# Set to true in cloud deployments to skip Ollama startup
DISABLE_OLLAMA=false

# Railway — set automatically by Railway; used by Vercel redirect
RAILWAY_APP_URL=https://your-app.up.railway.app
