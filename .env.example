# Claude API
ANTHROPIC_API_KEY=your_api_key_here

# AWS / S3 — required for cloud deployments; leave blank to use local file
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_DATA_KEY=SAP_GL_Account_Data.xlsx

# Vercel redirect — set this in the Vercel project dashboard
# to your Streamlit Community Cloud URL (e.g. https://your-app.streamlit.app)
STREAMLIT_APP_URL=https://your-app.streamlit.app

# Local/Docker Ollama model (optional — only used for local dev with Docker)
OLLAMA_MODEL=llama3.2
DISABLE_OLLAMA=false
